## Ignore build outputs and user-specific files

# Build results
bin/
obj/

# Visual Studio / VS Code
.vs/
.vscode/

# Rider / JetBrains
.idea/

# User-specific files
*.user
*.userosscache
*.suo
*.userprefs

# Logs
logs/
*.log

# NuGet
packages/
*.nupkg

# Generated files
Generated_*/

# SQLite / local DB files
*.db
*.db-shm
*.db-wal

# IIS Express
.vs/

# Publish output
publish/

