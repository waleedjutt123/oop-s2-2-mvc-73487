@model FoodSafetyTracker.Models.Inspection
@{
    ViewData["Title"] = "Delete Inspection";
}

<h1>Delete Inspection</h1>

<h3>Are you sure you want to delete this?</h3>
<div>
    <dl class="row">
        <dt class="col-sm-2">Premises</dt>
        <dd class="col-sm-10">@(Model.Premises?.Name ?? "-")</dd>
        <dt class="col-sm-2">@Html.DisplayNameFor(m => m.InspectionDate)</dt>
        <dd class="col-sm-10">@Model.InspectionDate.ToString("d")</dd>
        <dt class="col-sm-2">@Html.DisplayNameFor(m => m.Outcome)</dt>
        <dd class="col-sm-10">@Model.Outcome</dd>
    </dl>
    <form asp-action="Delete" method="post">
        <input type="hidden" asp-for="Id" />
        <button type="submit" class="btn btn-danger">Delete</button>
        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
    </form>
</div>
