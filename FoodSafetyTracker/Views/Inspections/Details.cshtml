@model FoodSafetyTracker.Models.Inspection
@{
    ViewData["Title"] = "Inspection Details";
}
@using FoodSafetyTracker.Data

<h1>Details</h1>

<div>
    <h4>Inspection</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">Premises</dt>
        <dd class="col-sm-10">@(Model.Premises?.Name ?? "-")</dd>
        <dt class="col-sm-2">@Html.DisplayNameFor(m => m.InspectionDate)</dt>
        <dd class="col-sm-10">@Model.InspectionDate.ToString("d")</dd>
        <dt class="col-sm-2">@Html.DisplayNameFor(m => m.Score)</dt>
        <dd class="col-sm-10">@Model.Score</dd>
        <dt class="col-sm-2">@Html.DisplayNameFor(m => m.Outcome)</dt>
        <dd class="col-sm-10">@Model.Outcome</dd>
        <dt class="col-sm-2">@Html.DisplayNameFor(m => m.Notes)</dt>
        <dd class="col-sm-10">@(Model.Notes ?? "-")</dd>
        <dt class="col-sm-2">Follow-ups</dt>
        <dd class="col-sm-10">@(Model.FollowUps?.Count ?? 0)</dd>
    </dl>
</div>
<div>
    @if (User.IsInRole(DbInitializer.RoleAdmin) || User.IsInRole(DbInitializer.RoleInspector))
    {
        <a asp-action="Edit" asp-route-id="@Model.Id">Edit</a>
        <text> | </text>
    }
    <a asp-action="Index">Back to List</a>
</div>
