@model FoodSafetyTracker.Models.Inspection
@{
    ViewData["Title"] = "Create Inspection";
}
<h1>Create Inspection</h1>
<form asp-action="Create" method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <div class="mb-2">
        <label class="form-label">Premises</label>
        <select asp-for="PremisesId" class="form-control" asp-items="ViewBag.PremisesId"></select>
    </div>
    <div class="mb-2">
        <label asp-for="InspectionDate" class="form-label"></label>
        <input asp-for="InspectionDate" class="form-control" type="date" />
        <span asp-validation-for="InspectionDate" class="text-danger"></span>
    </div>
    <div class="mb-2">
        <label asp-for="Score" class="form-label"></label>
        <input asp-for="Score" class="form-control" type="number" min="0" max="100" />
        <span asp-validation-for="Score" class="text-danger"></span>
    </div>
    <div class="mb-2">
        <label asp-for="Outcome" class="form-label"></label>
        <select asp-for="Outcome" class="form-control" asp-items="Html.GetEnumSelectList<FoodSafetyTracker.Models.InspectionOutcome>()"></select>
    </div>
    <div class="mb-2">
        <label asp-for="Notes" class="form-label"></label>
        <textarea asp-for="Notes" class="form-control" rows="2"></textarea>
    </div>
    <button type="submit" class="btn btn-primary">Create</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
