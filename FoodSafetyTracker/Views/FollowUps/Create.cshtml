@model FoodSafetyTracker.Models.FollowUp
@{
    ViewData["Title"] = "Create Follow-up";
}
<h1>Create Follow-up</h1>
<form asp-action="Create" method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <div class="mb-2">
        <label class="form-label">Inspection</label>
        <select asp-for="InspectionId" class="form-control" asp-items="ViewBag.InspectionId"></select>
    </div>
    <div class="mb-2">
        <label asp-for="DueDate" class="form-label"></label>
        <input asp-for="DueDate" class="form-control" type="date" />
        <span asp-validation-for="DueDate" class="text-danger"></span>
    </div>
    <div class="mb-2">
        <label asp-for="Status" class="form-label"></label>
        <select asp-for="Status" class="form-control" asp-items="Html.GetEnumSelectList<FoodSafetyTracker.Models.FollowUpStatus>()"></select>
    </div>
    <button type="submit" class="btn btn-primary">Create</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
