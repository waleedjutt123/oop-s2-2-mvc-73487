@model FoodSafetyTracker.Models.FollowUp
@{
    ViewData["Title"] = "Edit Follow-up";
}

<h1>Edit Follow-up</h1>

<form asp-action="Edit" method="post">
    <input type="hidden" asp-for="Id" />
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <div class="mb-2">
        <label asp-for="InspectionId" class="form-label">Inspection</label>
        <select asp-for="InspectionId" class="form-control" asp-items="ViewBag.InspectionId"></select>
    </div>
    <div class="mb-2">
        <label asp-for="DueDate" class="form-label"></label>
        <input asp-for="DueDate" class="form-control" type="date" />
        <span asp-validation-for="DueDate" class="text-danger"></span>
    </div>
    <div class="mb-2">
        <label asp-for="Status" class="form-label"></label>
        <select asp-for="Status" class="form-control" asp-items="Html.GetEnumSelectList<FoodSafetyTracker.Models.FollowUpStatus>()"></select>
    </div>
    <div class="mb-2">
        <label asp-for="ClosedDate" class="form-label"></label>
        <input asp-for="ClosedDate" class="form-control" type="date" />
        <span asp-validation-for="ClosedDate" class="text-danger"></span>
        <small class="text-muted">Required when Status is Closed.</small>
    </div>
    <button type="submit" class="btn btn-primary">Save</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
