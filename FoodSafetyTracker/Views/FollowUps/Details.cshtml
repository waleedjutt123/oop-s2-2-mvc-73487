@model FoodSafetyTracker.Models.FollowUp
@{
    ViewData["Title"] = "Follow-up Details";
}
<h1>Details</h1>
<dl class="row">
    <dt class="col-sm-2">Inspection</dt>
    <dd class="col-sm-10">#@Model.InspectionId @(Model.Inspection?.Premises != null ? " - " + Model.Inspection.Premises.Name : "")</dd>
    <dt class="col-sm-2">Due Date</dt>
    <dd class="col-sm-10">@Model.DueDate.ToString("d")</dd>
    <dt class="col-sm-2">Status</dt>
    <dd class="col-sm-10">@Model.Status</dd>
    <dt class="col-sm-2">Closed Date</dt>
    <dd class="col-sm-10">@(Model.ClosedDate?.ToString("d") ?? "-")</dd>
</dl>
<div>
    @if (User.IsInRole("Admin") || User.IsInRole("Inspector"))
    {
        <a asp-action="Edit" asp-route-id="@Model.Id">Edit</a>
        <text> | </text>
    }
    <a asp-action="Index">Back to List</a>
</div>
