@model FoodSafetyTracker.Models.FollowUp
@{
    ViewData["Title"] = "Follow-up Details";
}
@using FoodSafetyTracker.Data

<h1>Details</h1>

<div>
    <h4>FollowUp</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">Inspection</dt>
        <dd class="col-sm-10">#@Model.InspectionId @(Model.Inspection?.Premises != null ? " - " + Model.Inspection.Premises.Name : "")</dd>
        <dt class="col-sm-2">@Html.DisplayNameFor(m => m.DueDate)</dt>
        <dd class="col-sm-10">@Model.DueDate.ToString("d")</dd>
        <dt class="col-sm-2">@Html.DisplayNameFor(m => m.Status)</dt>
        <dd class="col-sm-10">@Model.Status</dd>
        <dt class="col-sm-2">@Html.DisplayNameFor(m => m.ClosedDate)</dt>
        <dd class="col-sm-10">@(Model.ClosedDate?.ToString("d") ?? "-")</dd>
    </dl>
</div>
<div>
    @if (User.IsInRole(DbInitializer.RoleAdmin) || User.IsInRole(DbInitializer.RoleInspector))
    {
        <a asp-action="Edit" asp-route-id="@Model.Id">Edit</a>
        <text> | </text>
    }
    <a asp-action="Index">Back to List</a>
</div>
