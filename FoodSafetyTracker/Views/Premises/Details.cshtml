@model FoodSafetyTracker.Models.Premises
@{
    ViewData["Title"] = "Premises Details";
}

<h1>Details</h1>

<div>
    <h4>Premises</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">@Html.DisplayNameFor(m => m.Name)</dt>
        <dd class="col-sm-10">@Model.Name</dd>
        <dt class="col-sm-2">@Html.DisplayNameFor(m => m.Address)</dt>
        <dd class="col-sm-10">@Model.Address</dd>
        <dt class="col-sm-2">@Html.DisplayNameFor(m => m.Town)</dt>
        <dd class="col-sm-10">@Model.Town</dd>
        <dt class="col-sm-2">@Html.DisplayNameFor(m => m.RiskRating)</dt>
        <dd class="col-sm-10">@Model.RiskRating</dd>
        <dt class="col-sm-2">Inspections</dt>
        <dd class="col-sm-10">@(Model.Inspections?.Count ?? 0)</dd>
    </dl>
</div>
<div>
    @if (User.IsInRole(FoodSafetyTracker.Data.DbInitializer.RoleAdmin))
    {
        <a asp-action="Edit" asp-route-id="@Model.Id">Edit</a>
        <text> | </text>
    }
    <a asp-action="Index">Back to List</a>
</div>
