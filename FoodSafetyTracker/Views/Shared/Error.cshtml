@model ErrorViewModel
@{
    ViewData["Title"] = "Error";
}

<h1 class="text-danger">Something went wrong</h1>
<p class="lead">An error occurred while processing your request. Please try again or contact support.</p>

@if (Model.ShowRequestId)
{
    <p class="text-muted small">Request ID: <code>@Model.RequestId</code></p>
}

<p><a asp-controller="Home" asp-action="Index" class="btn btn-primary">Return to Dashboard</a></p>
